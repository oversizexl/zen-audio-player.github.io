{
  "name": "zen-audio-player",
  "version": "1.1.0",
  "description": "Listen to YouTube videos, without the distracting visuals.",
  "main": "",
  "scripts": {
    "lint:js": "bunx eslint js/*.js",
    "lint:tests": "bunx eslint test/*.js",
    "lint:html": "bunx htmlhint index.html",
    "lint:css": "bunx stylelint css/*.css",
    "lint": "bun run lint:js && bun run lint:html && bun run lint:css && bun run lint:tests",
    "pretest": "bun run lint",
    "test": "bunx mocha",
    "fix": "bunx eslint js/everything.js test/*.js --fix",
    "fest": "bun run fix && bun run test",
    "start": "bunx http-server --cors -o -a localhost"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zen-audio-player/zen-audio-player.github.io.git"
  },
  "keywords": [
    "youtube",
    "audio",
    "zen",
    "player"
  ],
  "author": "Shakeel Mohamed",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/zen-audio-player/zen-audio-player.github.io/issues"
  },
  "homepage": "https://zen-audio-player.github.io",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "htmlhint": "^1.9.1",
    "http-server": "^14.1.1",
    "mocha": "^11.7.5",
    "stylelint": "^17.4.0",
    "stylelint-config-recess-order": "^7.6.1",
    "stylelint-config-standard": "^40.0.0"
  },
  "engines": {
    "node": ">=20.x"
  }
}
